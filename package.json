{
  "name": "plainvault",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "start": "pnpm -r --parallel start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "prisma:generate": "prisma generate"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "next": "16.2.5",
    "prisma": "5",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@prisma/client": "5",
    "marked": "^18.0.3",
    "sanitize-html": "^2.17.3"
  }
}