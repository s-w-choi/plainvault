DATABASE_URL="file:./data/vault.db"
VAULT_ENCRYPTION_KEY="replace-with-32-byte-base64-encoded-key"
NODE_ENV="development"

# Admin account seeding (used by `pnpm db:seed`)
INIT_ADMIN_EMAIL="admin@plainvault.local"
INIT_ADMIN_PASSWORD="plainvault-admin"
INIT_ADMIN_NAME="Admin User"

MAX_FILE_CONTENT_BYTES="1048576"

RATE_LIMIT_LOGIN_WINDOW_SECONDS="300"
RATE_LIMIT_LOGIN_MAX_ATTEMPTS="10"
